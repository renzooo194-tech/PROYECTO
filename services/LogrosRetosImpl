package ProyectoEstudiaYa.webapp.services;

import org.springframework.stereotype.Service;
import ProyectoEstudiaYa.webapp.dto.UsuarioProgresoDTO;
import ProyectoEstudiaYa.webapp.entities.Logro;
import ProyectoEstudiaYa.webapp.repositories.LogroRepository;

import java.util.List;

@Service
public class LogroGamificacionServiceImpl implements LogroGamificacionService {

    private final LogroRepository logroRepository;

    private int puntos = 0;

    public LogroGamificacionServiceImpl(LogroRepository logroRepository) {
        this.logroRepository = logroRepository;
    }

    @Override
    public UsuarioProgresoDTO obtenerProgreso(Long usuarioId) {

        List<Logro> logros = logroRepository.findAll();

        UsuarioProgresoDTO dto = new UsuarioProgresoDTO();
        dto.setPuntos(puntos);
        dto.setLogros(logros);

        return dto;
    }

    @Override
    public UsuarioProgresoDTO completarReto(Long usuarioId, String reto) {

        puntos += 10;

        Logro logro = new Logro();
        logro.setNombre("Reto completado");
        logro.setDescripcion(reto);

        logroRepository.save(logro);

        return obtenerProgreso(usuarioId);
    }
}
