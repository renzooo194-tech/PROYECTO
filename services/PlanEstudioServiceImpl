package ProyectoEstudiaYa.webapp.services;

import org.springframework.stereotype.Service;
import ProyectoEstudiaYa.webapp.dto.*;

import java.util.*;

@Service
public class PlanEstudioServiceImpl implements PlanEstudioService {

    @Override
    public PlanEstudioResponseDTO generarHorario(PlanEstudioRequestDTO request) {

        PlanEstudioResponseDTO response = new PlanEstudioResponseDTO();
        Map<String, List<String>> horario = new HashMap<>();

        List<String> dias = List.of("Lunes", "Martes", "Miércoles", "Jueves", "Viernes");

        int cursoIndex = 0;

        for (int d = 0; d < request.getDiasDisponibles(); d++) {

            String dia = dias.get(d % dias.size());
            List<String> cursosDia = new ArrayList<>();

            for (int i = 0; i < request.getHorasDisponiblesPorDia(); i++) {
                cursosDia.add(request.getCursos().get(cursoIndex % request.getCursos().size()));
                cursoIndex++;
            }

            horario.put(dia, cursosDia);
        }

        response.setHorario(horario);
        return response;
    }
}
