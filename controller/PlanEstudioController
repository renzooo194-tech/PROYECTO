package ProyectoEstudiaYa.webapp.controller;

import org.springframework.web.bind.annotation.*;
import ProyectoEstudiaYa.webapp.dto.*;
import ProyectoEstudiaYa.webapp.services.PlanEstudioService;

@RestController
@RequestMapping("/plan-estudio")
public class PlanEstudioController {

    private final PlanEstudioService service;

    public PlanEstudioController(PlanEstudioService service) {
        this.service = service;
    }

    @PostMapping("/generar")
    public PlanEstudioResponseDTO generar(@RequestBody PlanEstudioRequestDTO request) {
        return service.generarHorario(request);
    }
}
