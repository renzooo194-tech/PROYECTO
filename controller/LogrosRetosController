package ProyectoEstudiaYa.webapp.controller;

import org.springframework.web.bind.annotation.*;
import ProyectoEstudiaYa.webapp.dto.UsuarioProgresoDTO;
import ProyectoEstudiaYa.webapp.services.LogroGamificacionService;

@RestController
@RequestMapping("/gamificacion")
public class LogroGamificacionController {

    private final LogroGamificacionService service;

    public LogroGamificacionController(LogroGamificacionService service) {
        this.service = service;
    }

    @GetMapping("/{usuarioId}")
    public UsuarioProgresoDTO obtener(@PathVariable Long usuarioId) {
        return service.obtenerProgreso(usuarioId);
    }

    @PostMapping("/reto")
    public UsuarioProgresoDTO completar(
            @RequestParam Long usuarioId,
            @RequestParam String reto) {

        return service.completarReto(usuarioId, reto);
    }
}
